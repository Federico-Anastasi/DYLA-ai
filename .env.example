# Dyla — local environment
#
# Copy this file to `.env` and fill in the paths for your machine. Both variables are
# optional: without them Dyla downloads its own llama-server and keeps models under
# runtime/. Set them when you already have a build and a model collection of your own.

# Your own llama-server build. If unset, Dyla downloads one on first run.
# LLAMA_SERVER=C:\path\to\llama-cpp\llama-server.exe

# Where your .gguf models live. If unset, Dyla uses runtime/.
# MODELS_DIR=C:\path\to\models
