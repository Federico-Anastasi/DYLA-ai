# Normalise line endings in the repository so a checkout on Windows and one on macOS
# don't produce diffs that are pure carriage returns.
* text=auto eol=lf

# These have to keep CRLF: Windows runs them, and a .bat with LF endings can fail in
# ways that are hard to diagnose.
*.bat text eol=crlf
*.ps1 text eol=crlf

*.png binary
*.jpg binary
*.pdf binary
*.xlsx binary
*.docx binary
*.pptx binary
